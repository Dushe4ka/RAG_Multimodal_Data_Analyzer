DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres?sslmode=disable
OPENAI_API_KEY=your_key_here
# Модель для основного диалога (LangChain init_chat_model)
CHAT_MODEL=gpt-4.1-mini
# Модель для суммаризации истории
SUMMARY_MODEL=gpt-4.1-mini
# Триггер суммаризации
SUMMARY_TRIGGER_TOKENS=4000
# Сколько последних сообщений держать несуммаризованными
SUMMARY_KEEP_MESSAGES=20
